# =================================================
# AEM Monorepo Environment Variables
# =================================================

# Supabase (Required for all apps)
# ---------------------------------
# URL for your Supabase project
NEXT_PUBLIC_SUPABASE_URL=
# Anon key (public, safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service Role key (secret, for server-side scripts like seeding)
SUPABASE_SERVICE_ROLE_KEY=

# Database (For scripts)
# ---------------------------------
# Direct connection string for database setup/migrations
POSTGRES_URL_NON_POOLING=

# App URLs (For Metadata and SEO)
# ---------------------------------
# The canonical URL for the main 'web' application
NEXT_PUBLIC_WEB_URL=https://www.aemdevweb.com
# The canonical URL for the 'unlink-th' application
NEXT_PUBLIC_UNLINK_URL=https://www.unlink-th.com
