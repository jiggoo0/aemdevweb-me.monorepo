# .geminiignore - Optimization for AI Context Window
# ห้าม Gemini อ่านหรือค้นหาในโฟลเดอร์/ไฟล์เหล่านี้เพื่อความรวดเร็ว

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
.next/
out/
build/
dist/
.swc/

# Logs & Caches
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
.stylelintcache
.tsbuildinfo

# Environment variables (Security)
.env*
!.env.example

# Media & Assets (AI doesn't need to read raw binary of images)
public/**/*.png
public/**/*.jpg
public/**/*.jpeg
public/**/*.gif
public/**/*.svg
public/**/*.ico
public/**/*.webp
public/**/*.mp4

# OS/Editor files
.DS_Store
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
