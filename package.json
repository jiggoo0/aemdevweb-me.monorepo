{
  "name": "aemdevweb-me.monorepo",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "scripts": {
    "audit": "pnpm exec tsx scripts/integrity-audit.ts",
    "audit:all": "pnpm run standardize && pnpm run format && pnpm run lint && pnpm run typecheck && pnpm run audit:knip && pnpm run audit",
    "audit:knip": "pnpm exec knip",
    "build": "pnpm -r build",
    "clean": "pnpm -r exec rm -rf .next node_modules && rm -rf node_modules && find apps packages -name \"*.bak\" -type f -delete",
    "db:seed": "pnpm exec tsx scripts/seed-provinces.ts && pnpm exec tsx scripts/seed-projects.ts && pnpm exec tsx scripts/seed-blog.ts && pnpm exec tsx scripts/seed-trust.ts",
    "db:setup": "pnpm exec tsx scripts/setup-database.ts",
    "db:sync": "pnpm exec tsx scripts/sync-real-assets.ts",
    "db:test": "pnpm exec tsx scripts/test-database-ops.ts",
    "dev": "NODE_OPTIONS='--max-old-space-size=2048' pnpm -r --parallel dev",
    "dev:unlink": "NODE_OPTIONS='--max-old-space-size=2048' pnpm --filter unlink-th dev",
    "dev:web": "NODE_OPTIONS='--max-old-space-size=2048' pnpm --filter web dev",
    "env:sync": "./scripts/monorepo-env-sync.sh",
    "fix:all": "pnpm run format:fix && pnpm run standardize && pnpm run lint --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "standardize": "./scripts/monorepo-standardizer.sh",
    "start": "pnpm -r --parallel start",
    "typecheck": "pnpm -r run typecheck"
  },
  "dependencies": {
    "@next/swc-wasm-nodejs": "^16.2.3",
    "dotenv": "^17.4.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@supabase/supabase-js": "^2.103.0",
    "@types/node": "^22.19.15",
    "eslint": "^9.7.0",
    "eslint-plugin-only-warn": "^1.2.1",
    "globals": "^17.4.0",
    "knip": "^6.3.0",
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.58.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "supportedArchitectures": {
      "cpu": [
        "x64",
        "arm64"
      ],
      "os": [
        "linux",
        "android"
      ]
    }
  }
}
